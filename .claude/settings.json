{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "extraKnownMarketplaces": {
    "kusari-plugins": {
      "source": { "source": "directory", "path": "." }
    }
  },
  "enabledPlugins": {
    "kusari-meta@kusari-plugins": true
  }
}